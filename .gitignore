# Build artifacts
/bin/
*.test
*.out

# Local config / data
/data/
*.db
*.db-journal
*.db-shm
*.db-wal

# IDE / editor
.idea/
.vscode/
*.swp
.DS_Store

# Docker buildx cache
/.buildx-cache/

# Local Go build cache (used by docker-run-with-cache flow)
/.gocache/

# Python tooling
__pycache__/
.pytest_cache/
*.py[cod]

# CI artifact: live OpenAPI schema dump from typecheck:api-types
/openapi.json

# Local-only compose overrides — never committed. Compose auto-loads
# `docker-compose.override.yml` and operators use it to inject smoke-test
# secrets, disable GPU reservations on CPU-only dev boxes, etc. The real
# stack contract lives in `docker-compose.yml` alone.
/docker-compose.override.yml

# Local-only UI-test scaffolding (Playwright). The compose override and the
# installed browser deps are operator conveniences — never part of the stack
# contract or the published image. Committing node_modules/ once swept in
# ~10MB of vendored Playwright; keep it out.
/docker-compose.uitest.yml
/node_modules/
/test-results/

